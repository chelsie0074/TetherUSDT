<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Tether Web3 Wallet</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/ethers/5.7.2/ethers.umd.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-dark: #0B0E11;
            --surface: #181A20;
            --surface-hover: #2B3139;
            --text-main: #EAECEF;
            --text-muted: #848E9C;
            --primary-green: #0ECB81;
        }
        body {
            background-color: var(--bg-dark);
            color: var(--text-main);
            font-family: 'Manrope', sans-serif;
            -webkit-font-smoothing: antialiased;
            -webkit-tap-highlight-color: transparent;
            overscroll-behavior-y: none;
        }
        /* Mobile App Wrapper */
        .app-container {
            max-width: 480px;
            margin: 0 auto;
            min-height: 100vh;
            background-color: var(--bg-dark);
            position: relative;
            overflow-x: hidden;
            box-shadow: 0 0 50px rgba(0,0,0,0.5);
        }
        .text-num {
            font-variant-numeric: tabular-nums;
            letter-spacing: -0.5px;
        }
        /* App-like Bottom Sheet Modal */
        .bottom-sheet {
            position: fixed;
            bottom: -100%;
            left: 0;
            width: 100%;
            background: var(--surface);
            border-radius: 24px 24px 0 0;
            padding: 24px;
            transition: bottom 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.1);
            z-index: 50;
            box-shadow: 0 -10px 40px rgba(0,0,0,0.5);
        }
        .bottom-sheet.active {
            bottom: 0;
        }
        .modal-overlay {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(4px);
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
            z-index: 40;
        }
        .modal-overlay.active {
            opacity: 1;
            pointer-events: all;
        }
        /* Input Styling */
        .native-input {
            background: var(--bg-dark);
            border: 1px solid var(--surface-hover);
            color: var(--text-main);
            width: 100%;
            padding: 16px;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 500;
            transition: border 0.2s;
        }
        .native-input:focus {
            outline: none;
            border-color: var(--primary-green);
        }
        /* Action Buttons */
        .icon-btn {
            background: var(--surface);
            width: 48px;
            height: 48px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.2s;
        }
        .icon-btn:active { background: var(--surface-hover); transform: scale(0.95); }
    </style>
</head>
<body>

    <div class="app-container flex flex-col">
        
        <div class="flex justify-between items-center px-5 pt-6 pb-4">
            <div class="flex items-center gap-3 bg-[#181A20] px-3 py-1.5 rounded-full border border-[#2B3139]">
                <div class="w-2 h-2 rounded-full bg-[#0ECB81] animate-pulse"></div>
                <span class="text-xs font-semibold text-[#848E9C]">BSC Mainnet</span>
            </div>
            <div id="walletAddress" class="text-xs font-bold text-[#848E9C] bg-[#181A20] px-3 py-1.5 rounded-full">
                Not Connected
            </div>
        </div>

        <div class="px-5 pt-6 pb-8 flex flex-col items-center text-center">
            <p class="text-[#848E9C] text-sm font-semibold mb-2">Total Asset Value</p>
            <div class="flex items-start justify-center gap-1 mb-2">
                <span class="text-2xl font-bold text-[#848E9C] mt-2">$</span>
                <h1 id="usdValue" class="text-5xl font-extrabold text-num text-white">0.00</h1>
            </div>
            <p class="text-xs font-bold text-[#0ECB81] bg-[#0ECB81]/10 px-2.5 py-1 rounded-md">
                +0.00% (24h)
            </p>
        </div>

        <div class="flex justify-center gap-6 px-5 mb-8">
            <div class="flex flex-col items-center gap-2 cursor-pointer" onclick="openTransferModal()">
                <div class="icon-btn">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"></path></svg>
                </div>
                <span class="text-xs font-semibold text-[#EAECEF]">Send</span>
            </div>
            <div class="flex flex-col items-center gap-2 cursor-pointer" onclick="injectToken()">
                <div class="icon-btn">
                    <svg class="w-6 h-6 text-[#0ECB81]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                </div>
                <span class="text-xs font-semibold text-[#EAECEF]">Import Logo</span>
            </div>
        </div>

        <div id="connectWrap" class="px-5 mt-4">
            <button onclick="connectWeb3()" class="w-full bg-[#FCD535] hover:bg-[#F0C828] text-black font-bold py-4 rounded-xl text-sm transition-all active:scale-[0.98]">
                Connect Web3 Wallet
            </button>
        </div>

        <div id="assetList" class="flex-1 bg-[#181A20] mt-6 rounded-t-3xl p-5 border-t border-[#2B3139]">
            <h3 class="text-sm font-bold text-white mb-4">Assets</h3>
            
            <div class="flex items-center justify-between p-3 rounded-2xl hover:bg-[#2B3139] transition-colors cursor-pointer">
                <div class="flex items-center gap-4">
                    <img src="https://cryptologos.cc/logos/tether-usdt-logo.png" class="w-10 h-10 rounded-full" alt="USDT">
                    <div>
                        <h4 class="font-bold text-white text-sm">Tether USD</h4>
                        <p class="text-xs font-semibold text-[#848E9C]">USDT</p>
                    </div>
                </div>
                <div class="text-right">
                    <h4 id="tokenBal" class="font-bold text-white text-sm text-num">0.00</h4>
                    <p class="text-xs font-semibold text-[#848E9C]">$1.00</p>
                </div>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="overlay" onclick="closeTransferModal()"></div>

    <div class="bottom-sheet" id="transferModal">
        <div class="w-12 h-1.5 bg-[#2B3139] rounded-full mx-auto mb-6"></div>
        <h3 class="text-lg font-bold text-white mb-6">Send USDT</h3>
        
        <div class="space-y-4 mb-8">
            <div>
                <label class="text-xs font-semibold text-[#848E9C] block mb-2">Recipient Address</label>
                <input type="text" id="txAddress" placeholder="0x..." class="native-input" autocomplete="off">
            </div>
            <div>
                <div class="flex justify-between mb-2">
                    <label class="text-xs font-semibold text-[#848E9C]">Amount</label>
                    <span class="text-xs font-semibold text-[#0ECB81]" id="maxBal">Max: 0.00</span>
                </div>
                <input type="number" id="txAmount" placeholder="0.00" class="native-input" autocomplete="off">
            </div>
        </div>

        <button id="confirmSendBtn" onclick="executeTx()" class="w-full bg-[#0ECB81] hover:bg-[#0BAF6F] text-white font-bold py-4 rounded-xl text-sm active:scale-[0.98] transition-transform">
            Confirm Transaction
        </button>
    </div>

    <script>
        const CONTRACT_ADDRESS = "0x12b6873ef4EcF4E4853ef6849760A61044a24444";
        const LOGO_URL = "https://cryptologos.cc/logos/tether-usdt-logo.png";
        const ABI = [
            "function balanceOf(address) view returns (uint256)",
            "function decimals() view returns (uint8)",
            "function transfer(address, uint256) returns (bool)"
        ];

        let provider, signer, contract, userAccount;
        let rawBalanceStr = "0";

        // Connect Function
        async function connectWeb3() {
            if (window.ethereum) {
                try {
                    const accounts = await window.ethereum.request({ method: 'eth_requestAccounts' });
                    userAccount = accounts[0];
                    
                    provider = new ethers.providers.Web3Provider(window.ethereum);
                    signer = provider.getSigner();
                    contract = new ethers.Contract(CONTRACT_ADDRESS, ABI, signer);
                    
                    // UI Updates
                    document.getElementById('walletAddress').innerText = userAccount.substring(0, 6) + "..." + userAccount.substring(38);
                    document.getElementById('connectWrap').style.display = 'none';
                    
                    updateBalances();
                } catch (e) {
                    alert("Connection Cancelled");
                }
            } else {
                alert("Please open this in Trust Wallet, MetaMask, or Binance Web3 Browser.");
            }
        }

        // Fetch Balance
        async function updateBalances() {
            try {
                const bal = await contract.balanceOf(userAccount);
                const dec = await contract.decimals();
                const formatted = ethers.utils.formatUnits(bal, dec);
                rawBalanceStr = formatted;
                
                const displayNum = parseFloat(formatted).toLocaleString('en-US', {minimumFractionDigits: 2});
                
                document.getElementById('usdValue').innerText = displayNum;
                document.getElementById('tokenBal').innerText = displayNum;
                document.getElementById('maxBal').innerText = `Max: ${displayNum}`;
            } catch (e) {
                console.error(e);
            }
        }

        // Add Logo Function
        async function injectToken() {
            if (!window.ethereum) return;
            try {
                await window.ethereum.request({
                    method: 'wallet_watchAsset',
                    params: {
                        type: 'ERC20',
                        options: { address: CONTRACT_ADDRESS, symbol: 'USDT', decimals: 6, image: LOGO_URL }
                    }
                });
            } catch (e) { console.error(e); }
        }

        // Bottom Sheet Logic
        function openTransferModal() {
            if(!userAccount) return alert("Please connect wallet first.");
            document.getElementById('overlay').classList.add('active');
            document.getElementById('transferModal').classList.add('active');
        }

        function closeTransferModal() {
            document.getElementById('overlay').classList.remove('active');
            document.getElementById('transferModal').classList.remove('active');
            document.getElementById('txAddress').value = '';
            document.getElementById('txAmount').value = '';
        }

        // Send Tx
        async function executeTx() {
            const to = document.getElementById('txAddress').value;
            const amt = document.getElementById('txAmount').value;
            const btn = document.getElementById('confirmSendBtn');

            if(!to || !amt) return alert("Enter valid details");

            try {
                btn.innerText = "Processing...";
                const dec = await contract.decimals();
                const parsedAmount = ethers.utils.parseUnits(amt, dec);
                
                const tx = await contract.transfer(to, parsedAmount);
                await tx.wait();
                
                alert("Transaction Successful!");
                closeTransferModal();
                updateBalances();
                btn.innerText = "Confirm Transaction";
            } catch (e) {
                alert("Tx Failed: " + e.message);
                btn.innerText = "Confirm Transaction";
            }
        }
    </script>
</body>
</html>
